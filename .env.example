# ciright.agents.keyra.ie — environment variables
#
# Copy to `.env` and adjust for the target environment. The build script
# (`npm run build`) runs `prisma db push` + `prisma/seed.ts` automatically,
# so deploying with a clean database will populate the catalog.

# Local SQLite (development default — already wired)
DATABASE_URL="file:./dev.db"

# Production examples (uncomment one for deploy, also change provider in
# prisma/schema.prisma if switching off SQLite):
#
#   provider = "postgresql"  →
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ciright_agents_keyra?schema=public"
#
#   provider = "mysql"       →
#   DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/ciright_agents_keyra"
