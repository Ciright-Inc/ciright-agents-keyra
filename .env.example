# ciright.agents.keyra.ie — environment variables
#
# Copy to `.env` and adjust for the target environment. On Railway,
# `scripts/railway-start.sh` runs `prisma db push` + seed at container start.

# PostgreSQL (local Docker, Railway Postgres plugin, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ciright_agents_keyra?schema=public"

# Railway: link a Postgres service and set on this service:
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}
#   NODE_ENV=production

# --- Keyra session (same flow as keyra.ie admin) ---
# Required in production — min 32 random bytes as hex/base64.
KEYRA_SESSION_SECRET=""

# SimSecure auth backend (production: https://auth.keyra.ie)
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL="https://auth.keyra.ie"
SIMSECURE_AUTH_BACKEND_URL="https://auth.keyra.ie"

# This catalog app's public URL (used for Get Started return + session bridge)
NEXT_PUBLIC_CATALOG_SITE_URL="http://localhost:3040"
# NEXT_PUBLIC_CATALOG_SITE_URL="https://ciright-agents-keyra-production.up.railway.app"

NEXT_PUBLIC_GET_STARTED_URL="https://get-started.keyra.ie"

# Local dev: auto-login without Get Started (must match seeded AdminUser.phoneE164)
KEYRA_DEV_SESSION_PHONE="+353871234567"
